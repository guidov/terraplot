{
  "name": "terraplot",
  "version": "0.1.0",
  "description": "Cartopy-inspired scientific field visualization for 3D browser globes",
  "type": "module",
  "main": "dist/terraplot.cjs",
  "module": "dist/terraplot.js",
  "exports": {
    ".": {
      "import": "./dist/terraplot.js",
      "require": "./dist/terraplot.cjs"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "keywords": ["globe", "cartopy", "gis", "climate", "weather", "visualization", "three.js", "scientific"],
  "license": "MIT",
  "peerDependencies": {
    "three": ">=0.150.0"
  },
  "dependencies": {
    "d3-contour": "^4.0.2",
    "d3-geo": "^3.1.1",
    "d3-scale-chromatic": "^3.1.0"
  },
  "devDependencies": {
    "three": "^0.184.0",
    "vite": "^5.0.0"
  }
}
